{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/require-verify.sh",
            "timeout": 600,
            "statusMessage": "Checking verify gate before git commit/push..."
          }
        ]
      }
    ]
  }
}
