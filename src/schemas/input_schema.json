{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forward-deployed-ai-workbench/schemas/input_schema.json",
  "title": "TelemetryInputRow",
  "description": "Required columns for a single telemetry record ingested from CSV",
  "type": "object",
  "required": [
    "timestamp",
    "battery_level",
    "cpu_utilization",
    "sensor_drift",
    "comms_link",
    "temperature"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 sample time"
    },
    "battery_level": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "cpu_utilization": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "sensor_drift": {
      "type": "number",
      "minimum": 0
    },
    "comms_link": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "temperature": {
      "type": "number"
    }
  },
  "additionalProperties": true
}